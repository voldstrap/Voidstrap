<ui:UiPage x:Class="Voidstrap.UI.Elements.Installer.Pages.WelcomePage"
           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
           xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
           xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
           xmlns:local="clr-namespace:Voidstrap.UI.Elements.Installer.Pages"
           xmlns:models="clr-namespace:Voidstrap.UI.ViewModels"
           xmlns:dmodels="clr-namespace:Voidstrap.UI.ViewModels.Installer"
           xmlns:resources="clr-namespace:Voidstrap.Resources"
           xmlns:controls="clr-namespace:Voidstrap.UI.Elements.Controls"
           mc:Ignorable="d" 
           d:DataContext="{d:DesignInstance dmodels:WelcomeViewModel, IsDesignTimeCreatable=True}"
           d:DesignHeight="450" d:DesignWidth="800"
           Title="WelcomePage"
           Scrollable="True"
           Loaded="UiPage_Loaded">

    <StackPanel>

        <controls:MarkdownTextBlock FontSize="14" MarkdownText="{Binding MainText, Mode=OneWay}" TextWrapping="Wrap" />

        <TextBlock Margin="0,24,0,0" FontSize="14" Text="{x:Static resources:Strings.Installer_Welcome_NextToContinue}" TextWrapping="Wrap" Visibility="{Binding CanContinue, Converter={StaticResource BooleanToVisibilityConverter}}" />

        <TextBlock FontSize="14" TextWrapping="Wrap">
            You can use the following links to view everything about Voidstrap:
        </TextBlock>

        <TextBlock Margin="0,8,0,0" FontSize="14" TextWrapping="Wrap">
            <Hyperlink NavigateUri="https://voidstrapp.netlify.app/home" RequestNavigate="Hyperlink_RequestNavigate">
                Voidstrap Website
            </Hyperlink>
        </TextBlock>

        <TextBlock Margin="0,4,0,0" FontSize="14" TextWrapping="Wrap">
            <Hyperlink NavigateUri="https://voidstrapp.netlify.app/mods/mods" RequestNavigate="Hyperlink_RequestNavigate">
                Roblox/Voidstrap Mods
            </Hyperlink>
        </TextBlock>

        <TextBlock Margin="0,4,0,0" FontSize="14" TextWrapping="Wrap">
            <Hyperlink NavigateUri="https://voidstrapp.netlify.app/crosshairs/crosshairs" RequestNavigate="Hyperlink_RequestNavigate">
                Crosshairs
            </Hyperlink>
        </TextBlock>

        <TextBlock Margin="0,8,0,0" FontSize="14" TextWrapping="Wrap">
            See information about Voidstrap’s features and how to resolve issues:
        </TextBlock>

        <TextBlock Margin="0,4,0,0" FontSize="14" TextWrapping="Wrap">
            <Hyperlink NavigateUri="https://voidstrapp.netlify.app/documentation/documentation" RequestNavigate="Hyperlink_RequestNavigate">
                Documentation
            </Hyperlink>
        </TextBlock>

        <StackPanel Orientation="Horizontal" Margin="0,24,0,0">
            <ui:Button Content="Donate"
                       Icon="Heart24"
                       Margin="0,0,8,0"
                       Click="DonateButton_Click" />

            <ui:Button Content="Contributors"
                       Icon="People24"
                       Click="ContributorsButton_Click" />
        </StackPanel>
    </StackPanel>
</ui:UiPage>