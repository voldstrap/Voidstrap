<Window x:Class="Voidstrap.UI.Elements.Overlay.NotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStyle="None"
        Topmost="True"
        ShowInTaskbar="False"
        Width="300"
        Height="75">
    <Grid>
        <Border x:Name="NotificationBorder"
                CornerRadius="8"
                Padding="10"
                Opacity="0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Margin="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="1,1" EndPoint="0,0">
                    <GradientStop Offset="0.0" Color="{DynamicResource WindowBackgroundColorPrimary}"/>
                    <GradientStop Offset="0.7" Color="{DynamicResource WindowBackgroundColorSecondary}"/>
                    <GradientStop Offset="1.0" Color="{DynamicResource WindowBackgroundColorThird}"/>
                </LinearGradientBrush>
            </Border.Background>

            <Border.Effect>
                <DropShadowEffect 
                    Color="Black" 
                    BlurRadius="12" 
                    ShadowDepth="4" 
                    Opacity="0.6"/>
            </Border.Effect>

            <StackPanel Orientation="Horizontal">
                <Image x:Name="NotificationImage"
                       Width="40"
                       Height="40"
                       Margin="0,0,10,0"
                       Visibility="Collapsed"
                       Stretch="Uniform"/>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="NotificationText"
                               Foreground="White"
                               FontWeight="Bold"
                               FontSize="14"
                               TextWrapping="Wrap"/>

                    <Border Background="Transparent" 
        CornerRadius="2"
        Height="6"
        Margin="0,5,0,0"
        ClipToBounds="True">
                        <Grid x:Name="ProgressContainer" ClipToBounds="True">
                            <Rectangle x:Name="ProgressBar" 
                   HorizontalAlignment="Left"
                   Fill="White"
                   Width="0"
                   Height="6" 
                   RadiusX="2" RadiusY="2"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>